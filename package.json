{
  "name": "soloist",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && npm run lint:architecture && npm run lint:file-size",
    "lint:architecture": "node scripts/check-architecture.mjs",
    "lint:file-size": "node scripts/check-file-size.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fixtures:build": "node scripts/build-plugin-fixtures.mjs",
    "sdk:pack": "npm pack ./packages/soloist-plugin-sdk --dry-run --cache ./node_modules/.cache/npm",
    "example:install": "npm ci --prefix plugins-example/script-plugin",
    "example:build": "npm run build --prefix plugins-example/script-plugin",
    "example:package": "npm run package --prefix plugins-example/script-plugin",
    "test": "npm run fixtures:build && vitest run",
    "test:coverage": "npm run fixtures:build && vitest run --coverage",
    "quality": "npm run typecheck && npm run lint && npm run format:check && npm run test:coverage && npm run build",
    "test:rust": "npm run fixtures:build && cargo test --manifest-path src-tauri/Cargo.toml",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --no-bundle --ci",
    "tauri:bundle": "tauri build --ci"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "lucide-react": "^1.23.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "globals": "^16.5.0",
    "prettier": "^3.9.5",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.64.0",
    "vite": "^5.3.5",
    "vitest": "^4.1.9"
  }
}
